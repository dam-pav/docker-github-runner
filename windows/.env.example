# The repository or organization where the runner will be registered
# Repository: https://github.com/owner/repo
# Organization: https://github.com/owner (or https://github.com/orgs/owner)
REPO_URL=https://github.com/owner/repo

# GitHub PAT. It can instead be stored as GITHUB_TOKEN=... in
# C:\ProgramData\github-runner\credentials on the Windows Docker host.
GITHUB_TOKEN=

# Required and unique for every deployed runner
RUNNER_NAME=

# Number of runner containers to start. Must be a natural number. When greater
# than 1, runners are registered as RUNNER_NAME_1, RUNNER_NAME_2, and so on.
RUNNER_INSTANCES=1

# Optional image tag override. Development branches publish tags such as
# windows-ltsc2022-branch-feature-my-change. The registry and image name are fixed.
# RUNNER_IMAGE_TAG=windows-ltsc2022-latest

# Optional comma-separated custom labels
RUNNER_LABELS=

# Optional organization runner group. REPO_URL must be an organization URL.
# RUNNER_GROUP=Default

# Optional host directory containing the credentials file
# HOST_CRED_LOCATION=C:/ProgramData/github-runner

# Windows base-image release. It must be compatible with the Windows host.
WINDOWS_VERSION=ltsc2022

# Validate that nested Windows containers can read the runner workspace and
# BcContainerHelper directory through same-path host bind mounts.
VALIDATE_NESTED_DOCKER_MOUNTS=true

# Optional GitHub API retry settings
GH_API_RETRIES=6
GH_API_INITIAL_DELAY=1
GH_API_BACKOFF_MULT=2
